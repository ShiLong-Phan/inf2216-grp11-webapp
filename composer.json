{
  "name": "inf2216-grp11/webapp",
  "description": "Crumbly - A secure baking e-commerce web application",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.0",
    "stripe/stripe-php": "^18.1.0",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*"
  },
  "autoload": {
    "files": [
      "app/utils/dbconnect.php",
      "app/utils/functions.php"
    ]
  },
  "scripts": {
    "test": "phpunit --testdox",
    "check-syntax": "find ./app -name \"*.php\" -exec php -l {} \\;",
    "security-check": "grep -r \"eval\\\\(\" ./app || echo \"No eval() found\" && grep -r \"system\\\\(\" ./app || echo \"No system() found\""
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  }
}