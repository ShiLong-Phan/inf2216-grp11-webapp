# Prevent execution of PHP files in uploads directory
<Files "*.php">
    Order Allow,Deny
    Deny from all
</Files>

# Only allow image files
<FilesMatch "\.(jpg|jpeg|png|gif)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

# Deny everything else
<FilesMatch "^(?!.*\.(jpg|jpeg|png|gif)$).*$">
    Order Allow,Deny
    Deny from all
</FilesMatch>